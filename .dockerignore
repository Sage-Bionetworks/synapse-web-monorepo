# Docker build context exclusions for monorepo.
# Applied when building from the repo root (e.g., docker build -f apps/portals/nf/Dockerfile .)

# Dependencies (reinstalled inside Docker)
**/node_modules

# Build outputs (rebuilt inside Docker)
**/build
**/dist
**/.vite

# TypeScript incremental build cache
**/*.tsbuildinfo

# Test and coverage output
**/coverage
**/test-results
**/playwright-report

# Development files
**/.env.local
**/.env.*.local

# IDE and OS files
.idea
.vscode
**/.DS_Store

# Nx cache (machine-specific, causes integrity errors in Docker)
.nx

# Git
.git

# Plans (not needed in build)
plans/
