{
  "extends": "../../shared/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "target": "esnext",
    "allowJs": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.json",
    "src/**/*.cjs",
    ".storybook/**/*/.mts"
  ],
  "references": [
    {
      "path": "../synapse-client"
    },
    {
      "path": "../synapse-types"
    },
    {
      "path": "../markdown-it-synapse"
    },
    {
      "path": "../markdown-it-synapse-table"
    },
    { "path": "../vite-config" }
  ]
}
