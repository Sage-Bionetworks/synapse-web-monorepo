{
  "name": "@sage-bionetworks/synapse-portal-framework",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./style/*": "./src/style/*",
    "./*.svg": "./src/*.svg"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@react-hookz/web": "^25.1.1",
    "@sage-bionetworks/synapse-client": "workspace:*",
    "@sage-bionetworks/synapse-types": "workspace:*",
    "@tanstack/react-query": "5.80.10",
    "@upsetjs/react": "^1.11.0",
    "clone-deep": "^4.0.1",
    "dayjs": "^1.11.13",
    "katex": "^0.16.22",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "p-limit": "^6.2.0",
    "plotly.js-basic-dist": "^2.35.3",
    "react-cookie": "4.0.0",
    "react-plotly.js": "^2.6.0",
    "react-router": "^7.14.0",
    "react-switch": "^7.1.0",
    "react-type-animation": "^3.2.0",
    "sass": "^1.98.0",
    "synapse-react-client": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "clean": "rimraf coverage dist",
    "lint": "eslint src",
    "test": "vitest",
    "type-check": "tsc --build"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.7",
    "@types/lodash": "^4.17.16",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.13",
    "@types/plotly.js": "^2.35.5",
    "@types/react": "19.2.14",
    "@types/react-plotly.js": "^2.6.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vitest/utils": "^4.1.4",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "dotenv": "^16.5.0",
    "https-browserify": "^1.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^26.1.0",
    "memfs": "^3.5.3",
    "path-browserify": "^1.0.1",
    "pluralize": "^8.0.0",
    "postcss-normalize": "^10.0.1",
    "process": "^0.11.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "source-map-explorer": "^2.5.3",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "timers-browserify": "^2.0.12",
    "tslib": "^2.8.1",
    "tsx": "^4.19.4",
    "typescript": "6.0.3",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vite": "^8.0.8",
    "vite-config": "workspace:*",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4",
    "whatwg-fetch": "^3.6.20"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not ie <= 10",
      "not ie_mob <= 10",
      "not bb <= 10",
      "not op_mob <= 12.1"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
