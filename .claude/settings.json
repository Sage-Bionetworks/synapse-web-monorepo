{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/WorktreeCreate",
            "statusMessage": "Creating worktree..."
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/WorktreeRemove",
            "statusMessage": "Removing worktree..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .pnpm-installing ] && echo '{\"systemMessage\": \"pnpm install is running in the background. Run: tail -f .pnpm-install.log to follow progress.\"}' || true"
          }
        ]
      }
    ]
  }
}
