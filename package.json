{
  "name": "synapse-web-monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.16.0 <11"
  },
  "scripts": {
    "prepare": "husky && ./scripts/install-actionlint.sh",
    "lint:actions": "./bin/actionlint",
    "build": "nx run-many --target=build",
    "lint": "nx run-many --target=lint --quiet",
    "test": "nx run-many --target=test --coverage",
    "clean": "nx run-many --target=clean",
    "type-check": "nx run-many --target=type-check"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@nx/shared-fs-cache": "^5.0.2",
    "@types/node": "^22.19.13",
    "@types/semver": "^7.7.1",
    "@vitest/eslint-plugin": "^1.2.1",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.39.4",
    "eslint-plugin-barrel-files": "^2.1.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-testing-library": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nx": "22.6.3",
    "prettier": "^2.8.8",
    "rimraf": "^6.1.2",
    "semver": "^7.7.4",
    "tsx": "^4.19.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.32.0"
  },
  "npmClient": "pnpm",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,scss,css,md}": [
      "prettier --write"
    ],
    ".github/workflows/*.{yml,yaml}": [
      "./bin/actionlint"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "node-fetch": "^2.6.7",
      "glob@>=10.0.0 <11.0.0": "10.5.0",
      "js-yaml": "^4.1.1",
      "@nx/devkit@22.0.3>minimatch": "9.0.9",
      "mocha@10.8.2>serialize-javascript": "7.0.5",
      "@nestjs/core@11.1.17>path-to-regexp": "8.4.0"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
